# DashScope API Key (for Qwen models)
# Get your API key from: https://dashscope.console.aliyun.com/
# Example: DASHSCOPE_API_KEY=sk-d063bfa03846405c8821e328fb637572
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# E2B API Key (for sandbox environment)
# Get your API key from: https://e2b.dev/
# Example: E2B_API_KEY=e2b_8a5c7099485b881be08b594be7b7574440adf09c
E2B_API_KEY=e2b_your-e2b-api-key-here
